        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier --check .",
        "format:write": "prettier --write .",
        "lines": "cloc . --exclude-dir=dist,node_modules,.next --include-ext=ts,tsx --exclude-ext=d.ts,gen.ts",
        "lines:large": "cloc . --exclude-dir=dist,node_modules,.next --include-ext=ts,tsx --exclude-ext=d.ts,gen.ts --by-file --csv | awk -F, '$5 >= 500 {print $2, $5}'",
        "tree": "tree -I node_modules -I dist -I .next -I node_modules -I public",
        "gitleaks": "gitleaks detect --source ."
    },
